      "apiVersion": "2023-03-15-preview",
      "name": "[format('alert-avd-connection-errors-p2-{0}', parameters('klantCode'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "displayName": "[format('[{0}] AVD connection errors elevated (P2, dynamic)', parameters('klantCode'))]",
        "description": "Fires when AVD connection errors exceed the dynamically learned baseline.",
        "severity": 1,
        "enabled": true,
        "evaluationFrequency": "PT15M",
        "windowSize": "PT15M",
        "scopes": [
          "[parameters('workspaceId')]"
        ],
        "criteria": {
          "allOf": [
            {
              "query": "            WVDConnections\r\n            | where TimeGenerated > ago(15m)\r\n            | where State == \"Connected\"\r\n            | summarize Errors = countif(isnotempty(ClientSideIPAddress) == false)\r\n          ",
              "timeAggregation": "Count",
              "operator": "GreaterThan",
              "threshold": 5,
              "failingPeriods": {
                "numberOfEvaluationPeriods": 2,
                "minFailingPeriodsToAlert": 2
              }
            }
          ]
        },
        "actions": {
          "actionGroups": [
            "[parameters('actionGroupP2Id')]"
          ]
