      "apiVersion": "2020-10-01",
      "name": "[format('alert-servicehealth-incident-{0}', parameters('klantCode'))]",
      "location": "global",
      "tags": "[parameters('tags')]",
      "properties": {
        "enabled": true,
        "scopes": [
          "[subscription().id]"
        ],
        "condition": {
          "allOf": [
