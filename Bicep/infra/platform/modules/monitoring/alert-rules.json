    {
      "condition": "[variables('isManagedOrAbove')]",
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2023-03-15-preview",
      "name": "[format('alert-rsv-backup-failed-p2-{0}', parameters('klantCode'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "displayName": "[format('[{0}] RSV backup job failed (P2)', parameters('klantCode'))]",
        "description": "Fires on first backup job failure for any protected item.",
        "severity": 1,
        "enabled": true,
        "evaluationFrequency": "PT1H",
        "windowSize": "PT1H",
        "scopes": [
          "[parameters('workspaceId')]"
        ],
        "criteria": {
          "allOf": [
            {
              "query": "            AddonAzureBackupJobs\r\n            | where JobOperation == \"Backup\"\r\n            | where JobStatus == \"Failed\"\r\n          ",
              "timeAggregation": "Count",
              "operator": "GreaterThan",
              "threshold": 0,
              "failingPeriods": {
                "numberOfEvaluationPeriods": 1,
                "minFailingPeriodsToAlert": 1
              }
            }
          ]
        },
        "actions": {
          "actionGroups": [
            "[parameters('actionGroupP2Id')]"
          ]
        }
      }
    },
    {
      "condition": "[variables('isManagedOrAbove')]",
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2023-03-15-preview",
      "name": "[format('alert-rsv-backup-failed-p1-{0}', parameters('klantCode'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "displayName": "[format('[{0}] RSV backup job failed 2x consecutive (P1)', parameters('klantCode'))]",
        "description": "Fires when the same protected item fails backup twice in a row.",
        "severity": 0,
        "enabled": true,
        "evaluationFrequency": "PT1H",
        "windowSize": "PT2H",
        "scopes": [
          "[parameters('workspaceId')]"
        ],
        "criteria": {
          "allOf": [
            {
              "query": "            AddonAzureBackupJobs\r\n            | where JobOperation == \"Backup\"\r\n            | where JobStatus == \"Failed\"\r\n            | summarize Failures = count() by BackupItemUniqueId\r\n            | where Failures >= 2\r\n          ",
              "timeAggregation": "Count",
              "operator": "GreaterThan",
              "threshold": 0,
              "failingPeriods": {
                "numberOfEvaluationPeriods": 1,
                "minFailingPeriodsToAlert": 1
              }
            }
          ]
        },
        "actions": {
          "actionGroups": [
            "[parameters('actionGroupP1Id')]"
          ]
        }
      }
    },
