      "name": "[format('alert-azurefiles-throttling-p2-{0}', parameters('klantCode'))]",
      "location": "global",
      "tags": "[parameters('tags')]",
      "properties": {
        "description": "Azure Files SuccessWithThrottling sustained more than 10 minutes P2",
