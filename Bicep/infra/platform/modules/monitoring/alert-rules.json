        ],
        "criteria": {
          "allOf": [
            {
              "query": "            WVDErrors\r\n            | where TimeGenerated > ago(5m)\r\n            | where ServiceError == \"true\"\r\n            | summarize HostErrors = dcount(SessionHostName)\r\n            | where HostErrors > 2\r\n          ",
              "timeAggregation": "Count",
              "operator": "GreaterThan",
              "threshold": 0,
              "failingPeriods": {
                "numberOfEvaluationPeriods": 1,
                "minFailingPeriodsToAlert": 1
